{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Quarry/Quarry.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0",
        "BuildingDocs": "true"
      },
      "filter": "filterConfig.yml",
      "includePrivateMembers": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern",
      "templates/quarry"
    ],
    "globalMetadata": {
      "_appTitle": "Quarry Documentation",
      "_appName": "Quarry",
      "_appLogoPath": "images/logo-128.png",
      "_appFaviconPath": "images/logo-128.png",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_gitRepositoryUrl": "https://github.com/Dtronix/Quarry",
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/Dtronix/Quarry",
        "branch": "master",
        "apiSpecFolder": "docs/api"
      }
    },
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
