@page
@model Quarry.Sample.WebApp.Pages.Account.IndexModel
@{
    ViewData["Title"] = "Account";
    Layout = "_Layout";
}

<div class="card">
    <h1>Account</h1>
    @if (Model.Profile is not null)
    {
        <p><strong>Username:</strong> @Model.Profile.UserName</p>
        <p><strong>Email:</strong> @Model.Profile.Email</p>
        <p><strong>Member since:</strong> @Model.Profile.CreatedAt.ToString("yyyy-MM-dd")</p>
    }
</div>

<div class="card">
    <h2>Change Password</h2>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-message"></div>
        <div class="form-group">
            <label asp-for="Input.CurrentPassword"></label>
            <input asp-for="Input.CurrentPassword" type="password" />
            <span asp-validation-for="Input.CurrentPassword" class="validation-message"></span>
        </div>
        <div class="form-group">
            <label asp-for="Input.NewPassword"></label>
            <input asp-for="Input.NewPassword" type="password" />
            <span asp-validation-for="Input.NewPassword" class="validation-message"></span>
        </div>
        <div class="form-group">
            <label asp-for="Input.ConfirmNewPassword"></label>
            <input asp-for="Input.ConfirmNewPassword" type="password" />
            <span asp-validation-for="Input.ConfirmNewPassword" class="validation-message"></span>
        </div>
        <button type="submit" class="btn btn-primary">Change Password</button>
    </form>
</div>
