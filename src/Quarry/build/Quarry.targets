<Project>
  <!--
    Quarry emits generic interceptor helpers into the Quarry.Generated namespace
    regardless of where the consumer's QuarryContext subclass lives. Auto-register
    that namespace via <InterceptorsNamespaces> so consumers don't have to discover
    it via the CS9137 compiler error.

    Consumers must still add the namespace(s) of their own QuarryContext subclasses;
    QRY044 (Quarry.Analyzers) surfaces that gap at authoring time.
  -->
  <PropertyGroup>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Quarry.Generated</InterceptorsNamespaces>
  </PropertyGroup>

  <!--
    Expose a pipe-delimited copy of InterceptorsNamespaces to the QRY044 analyzer.
    Background: Roslyn's editorconfig key-value parser treats `;` inside a value as
    an inline-comment marker and truncates the captured value at the first `;`, so
    reading the raw `InterceptorsNamespaces` via `build_property.*` under-reads any
    multi-entry list. `|` is never a legal C# namespace character, so the `;` → `|`
    substitution is lossless. `Quarry.Generator.props` declares the same alt property
    for consumers who reference Quarry.Generator directly; this target makes sure
    every consumer of the Quarry package gets it regardless of Quarry.Generator
    reference shape.

    Declared as a Target (not a top-level PropertyGroup) so the `.Replace` expansion
    is deferred until after all upstream contributions to $(InterceptorsNamespaces)
    have been folded in by MSBuild.
  -->
  <ItemGroup>
    <CompilerVisibleProperty Include="QuarryInterceptorsNamespaces" />
  </ItemGroup>
  <Target Name="_QuarryComputeInterceptorsNamespacesFromTargets"
          BeforeTargets="GenerateMSBuildEditorConfigFileCore">
    <PropertyGroup>
      <QuarryInterceptorsNamespaces>$(InterceptorsNamespaces.Replace(';', '|'))</QuarryInterceptorsNamespaces>
    </PropertyGroup>
  </Target>
</Project>
